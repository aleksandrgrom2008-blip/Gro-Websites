# ── Server-side only (never exposed to the browser) ─────────────────────────

# Resend API key — create one at https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Where contact-form enquiries are delivered. Read only inside the API route
# handler at request time — it never appears in any client-delivered asset.
CONTACT_EMAIL=you@example.com

# ── Public (safe to expose — it is printed in every page's metadata) ────────

# Canonical site URL, no trailing slash. Drives metadataBase, sitemap.xml,
# robots.txt, canonical tags, and Open Graph URLs.
NEXT_PUBLIC_SITE_URL=https://www.your-domain.com
